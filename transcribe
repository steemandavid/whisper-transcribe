#!/usr/bin/env bash
# Whisper transcription pipeline v2 — bash orchestrator
# All Python lives in pipeline/ modules. This script parses flags, creates a
# scratch dir, and runs each stage via `docker run ... python -m pipeline.<stage>`.
#
# Usage: transcribe <audio_file> [options]
#   --quality      fast, medium, good, perfect — preset for models and quality params
#   --model        Override final transcription model (tiny, base, small, medium, large-v3)
#   --language     en, nl, fr, de, auto (default: auto-detect)
#   --prompt       Path to vocabulary/context hints file
#   --auto-prompt  Auto-generate vocabulary prompt via Ollama
#   --summary      Append LLM-generated summary to transcript
#   --enhance      Enable audio preprocessing (loudnorm, highpass, bandwidth extension)
#   --denoise      Enable DeepFilterNet3 denoising
#   --ensemble     Run multi-engine ASR with ROVER reconciliation
#   --correct      LLM post-correction (local Ollama)
#   --cloud-correct  LLM post-correction (cloud GLM via Z.ai)
#   --no-enhance   Override quality preset: disable enhance
#   --no-denoise   Override quality preset: disable denoise
#   --no-ensemble  Override quality preset: disable ensemble
#   --no-correct   Override quality preset: disable post-correction
#   --refresh-model  Force re-query of GLM models endpoint
#   --context      Free-text context for prompt building
#   --speakers N   Pin speaker count for diarization
#   --glossary     Path to glossary file
#   --diarize-model  community-1 or 3.1 (default: 3.1)
#   --ollama-model   Override Ollama model for auto-prompt/summary
#   --keep-intermediates  Preserve scratch dir for debugging
#
# Credentials (read at runtime, never baked into the image):
#   ~/.config/whisper/hf-token  — HuggingFace token for diarization
#   ~/.config/whisper/zai-key   — Z.ai API key for --cloud-correct

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
IMAGE="whisper-transcribe:2.0"

# Defaults
MODEL="medium"
LANGUAGE=""
INPUT_FILE=""
PROMPT_FILE=""
AUTO_PROMPT=false
SUMMARY=false
ENHANCE=false
DENOISE=false
ENSEMBLE=false
CORRECT=false
CLOUD_CORRECT=false
REFRESH_MODEL=false
CONTEXT=""
SPEAKERS=""
GLOSSARY_FILE=""
DIARIZE_MODEL="3.1"
OLLAMA_MODEL=""
OLLAMA_MODEL_EXPLICIT=false
QUALITY=""
KEEP_INTERMEDIATES=false
MODEL_EXPLICIT=false
NO_ENHANCE=false
NO_DENOISE=false
NO_ENSEMBLE=false
NO_CORRECT=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --model|-m)        MODEL="$2"; MODEL_EXPLICIT=true; shift 2 ;;
        --language|-l)     LANGUAGE="$2"; shift 2 ;;
        --prompt|-p)       PROMPT_FILE="$2"; shift 2 ;;
        --auto-prompt|-a)  AUTO_PROMPT=true; shift ;;
        --summary|-s)      SUMMARY=true; shift ;;
        --quality|-Q)      QUALITY="$2"; shift 2 ;;
        --enhance)         ENHANCE=true; shift ;;
        --denoise)         DENOISE=true; shift ;;
        --ensemble)        ENSEMBLE=true; shift ;;
        --correct)         CORRECT=true; shift ;;
        --cloud-correct)   CLOUD_CORRECT=true; shift ;;
        --refresh-model)   REFRESH_MODEL=true; shift ;;
        --context)         CONTEXT="$2"; shift 2 ;;
        --speakers)        SPEAKERS="$2"; shift 2 ;;
        --glossary)        GLOSSARY_FILE="$2"; shift 2 ;;
        --diarize-model)   DIARIZE_MODEL="$2"; shift 2 ;;
        --ollama-model|-o) OLLAMA_MODEL="$2"; OLLAMA_MODEL_EXPLICIT=true; shift 2 ;;
        --keep-intermediates) KEEP_INTERMEDIATES=true; shift ;;
        --no-enhance)      NO_ENHANCE=true; shift ;;
        --no-denoise)      NO_DENOISE=true; shift ;;
        --no-ensemble)     NO_ENSEMBLE=true; shift ;;
        --no-correct)      NO_CORRECT=true; shift ;;
        -h|--help)         head -33 "$0"; exit 0 ;;
        -*)                echo "Unknown option: $1"; exit 1 ;;
        *)                 INPUT_FILE="$(realpath "$1")"; shift ;;
    esac
done

if [ -z "$INPUT_FILE" ]; then
    echo "Usage: transcribe <audio_file> [options]"
    exit 1
fi

if $AUTO_PROMPT && [ -n "$PROMPT_FILE" ]; then
    echo "Error: --auto-prompt and --prompt are mutually exclusive"
    exit 1
fi

# --- Quality presets ---
if [ -n "$QUALITY" ]; then
    case "$QUALITY" in
        fast)
            SCAN_MODEL="base"
            BEAM_SIZE=2; BEST_OF=2; BATCH_SIZE=16
            QUALITY_MODEL="small"
            ;;
        medium)
            SCAN_MODEL="base"
            BEAM_SIZE=5; BEST_OF=5; BATCH_SIZE=12
            QUALITY_MODEL="medium"
            ;;
        good)
            SCAN_MODEL="medium"
            BEAM_SIZE=10; BEST_OF=10; BATCH_SIZE=8
            QUALITY_MODEL="large-v3"
            ;;
        perfect)
            SCAN_MODEL="large-v3"
            BEAM_SIZE=10; BEST_OF=10; BATCH_SIZE=8
            QUALITY_MODEL="large-v3"
            # --quality perfect enables all enhancements
            ENHANCE=true; DENOISE=true; ENSEMBLE=true; CORRECT=true
            ;;
        *)
            echo "Error: Unknown quality '$QUALITY' (fast, medium, good, perfect)"
            exit 1 ;;
    esac
    if $MODEL_EXPLICIT; then
        QUALITY_MODEL="$MODEL"
    fi
else
    SCAN_MODEL="medium"
    QUALITY_MODEL="$MODEL"
    BEAM_SIZE=10; BEST_OF=10; BATCH_SIZE=8
fi

# Apply --no-* overrides (these take precedence over quality presets)
if $NO_ENHANCE;  then ENHANCE=false;  fi
if $NO_DENOISE;  then DENOISE=false;  fi
if $NO_ENSEMBLE; then ENSEMBLE=false; fi
if $NO_CORRECT;  then CORRECT=false; CLOUD_CORRECT=false; fi

MODEL="$QUALITY_MODEL"
if [ "$SCAN_MODEL" = "large-v3" ]; then
    SCAN_MODEL_PATH="/opt/whisper-models/large-v3"
else
    SCAN_MODEL_PATH="$SCAN_MODEL"
fi

# Resolve input paths
INPUT_BASE="$(basename "${INPUT_FILE%.*}")"
INPUT_EXT="${INPUT_FILE##*.}"
INPUT_DIR="$(dirname "$INPUT_FILE")"

if [ ! -f "$INPUT_FILE" ]; then
    echo "Error: File not found: $INPUT_FILE"
    exit 1
fi

# --- Build Docker common args ---
DOCKER_ARGS=("-v" "$INPUT_DIR:/audio")
DOCKER_STAGE_EXTRA=()

# HF token
HF_TOKEN_MOUNT=""
if [ -f "$HOME/.config/whisper/hf-token" ]; then
    DOCKER_ARGS+=("-v" "$HOME/.config/whisper/hf-token:/run/secrets/hf-token:ro")
    HF_TOKEN_MOUNT="/run/secrets/hf-token"
else
    echo "Warning: No HuggingFace token at ~/.config/whisper/hf-token — speaker diarization will not identify speakers."
fi

# Glossary: resolve to a file path and mount it
GLOSSARY_MOUNT=""
GLOSSARY_RESOLVED=""
if [ -n "$GLOSSARY_FILE" ]; then
    GLOSSARY_RESOLVED="$(realpath "$GLOSSARY_FILE")"
elif [ -f "$HOME/.config/whisper/glossary.txt" ]; then
    GLOSSARY_RESOLVED="$HOME/.config/whisper/glossary.txt"
fi
if [ -n "$GLOSSARY_RESOLVED" ] && [ -f "$GLOSSARY_RESOLVED" ]; then
    DOCKER_ARGS+=("-v" "$GLOSSARY_RESOLVED:/run/glossary.txt:ro")
    GLOSSARY_MOUNT="/run/glossary.txt"
fi

# Z.ai API key
ZAI_ENV=()
if $CLOUD_CORRECT; then
    if [ -f "$HOME/.config/whisper/zai-key" ]; then
        ZAI_KEY="$(cat "$HOME/.config/whisper/zai-key")"
        ZAI_ENV=(-e "ZAI_API_KEY=$ZAI_KEY")
    fi
    CORRECT=true
fi

# Docker volume for HF cache
docker volume create whisper-hf-cache &>/dev/null
DOCKER_ARGS+=("-v" "whisper-hf-cache:/root/.cache/huggingface")

# Build image if not present
if ! docker image inspect "$IMAGE" &>/dev/null; then
    echo "Building Whisper image (~20 min on first run, downloading models and dependencies)..."
    docker build -t "$IMAGE" "$SCRIPT_DIR"
fi

# --- Scratch directory ---
SCRATCH="$INPUT_DIR/.whisper-run-$$"
mkdir -p "$SCRATCH"

# --- Ollama lifecycle ---
OLLAMA_WAS_ACTIVE=false

cleanup() {
    if ! $KEEP_INTERMEDIATES; then
        rm -rf "$SCRATCH"
    fi
    if $OLLAMA_WAS_ACTIVE; then
        sudo systemctl start ollama 2>/dev/null || echo "Warning: Cannot restart Ollama"
    fi
    rm -f "$INPUT_DIR/.whisper_auto_prompt_$$.txt"
    rm -f "$INPUT_DIR/.whisper_prompt_v1_$$.txt"
}
trap cleanup EXIT
if systemctl is-active --quiet ollama 2>/dev/null; then
    OLLAMA_WAS_ACTIVE=true
fi

ollama_ensure_running() {
    if ! systemctl is-active --quiet ollama 2>/dev/null; then
        echo "Starting Ollama..."
        sudo systemctl start ollama 2>/dev/null || echo "Warning: Cannot start Ollama (sudo required)"
        sleep 3
    fi
}
ollama_stop_for_gpu() {
    if systemctl is-active --quiet ollama 2>/dev/null; then
        echo "Stopping Ollama to free GPU memory..."
        sudo systemctl stop ollama 2>/dev/null || echo "Warning: Cannot stop Ollama (sudo required)"
        sleep 2
    fi
}

select_ollama_model() {
    ollama list 2>/dev/null | awk '
    NR == 1 { next }
    tolower($1) ~ /embed/ { next }
    {
        if ($4 == "GB") size = $3 * 1024;
        else if ($4 == "MB") size = $3;
        else size = 0;
        if (tolower($1) ~ /coder/) size *= 0.7;
        if (tolower($1) ~ /^qwen3/) size *= 0.5;
        if (tolower($1) ~ /instruct/) size *= 1.3;
        ver = 1.0;
        if (match(tolower($1), /[0-9]+(\.[0-9]+)?/)) {
            ver = substr(tolower($1), RSTART, RLENGTH) + 0;
        }
        gen_bonus = 1.0 + ver * 0.2;
        effective = size * gen_bonus;
        if (effective > best) { best = effective; name = $1 }
    }
    END { if (name != "") print name }'
}

# Helper: run a pipeline stage in Docker
# Extra docker args (e.g. -v mounts) can be passed via DOCKER_STAGE_EXTRA array
docker_stage() {
    local stage="$1"; shift
    docker run --rm --gpus all \
        "${DOCKER_ARGS[@]}" \
        "${ZAI_ENV[@]}" \
        "${DOCKER_STAGE_EXTRA[@]}" \
        "$IMAGE" \
        "pipeline.$stage" "$@"
}

# --- Prompt building ---
# The auto-prompt pipeline runs OUTSIDE Docker (it uses Ollama on the host)
# to manage VRAM between GPU Whisper and GPU Ollama.
PROMPT_FILE_MOUNT=""
AUTO_PROMPT_TEXT=""

if $AUTO_PROMPT; then
    # Resolve Ollama model
    ollama_ensure_running
    if [ -z "$OLLAMA_MODEL" ] || ! ollama list 2>/dev/null | grep -q "$OLLAMA_MODEL"; then
        OLLAMA_MODEL="$(select_ollama_model)"
        if [ -z "$OLLAMA_MODEL" ]; then
            echo "Warning: No suitable Ollama model found. Falling back to no prompt."
            AUTO_PROMPT=false
        else
            echo "Auto-selected Ollama: $OLLAMA_MODEL"
        fi
    fi
    ollama_stop_for_gpu

    if $AUTO_PROMPT; then
        LANG_FLAG="${LANGUAGE:-auto}"

        # Step 1: Quick scan
        echo "=== Auto-prompt Step 1: Quick scan ($SCAN_MODEL) ==="
        ROUGH_FILE="$SCRATCH/rough_scan.txt"
        docker_stage asr_engines "/audio/$INPUT_BASE.$INPUT_EXT" \
            --scratch "/audio/.whisper-run-$$" \
            --language "$LANG_FLAG" --model-path "$SCAN_MODEL_PATH" \
            --batch-size 8 \
            2>&1 || true
        # Extract text from the ASR JSON
        if [ -f "$SCRATCH/asr_engine_a.json" ]; then
            ROUGH_TEXT=$(python3 -c "
import json
d = json.load(open('$SCRATCH/asr_engine_a.json'))
print(' '.join(s['text'] for s in d.get('segments', []) if s.get('text','').strip()))
" 2>/dev/null || echo "")
        else
            ROUGH_TEXT=""
        fi

        if [ -z "$ROUGH_TEXT" ]; then
            echo "Warning: Quick scan empty. Falling back to no prompt."
            AUTO_PROMPT=false
        else
            echo "Quick scan: $(echo "$ROUGH_TEXT" | wc -w) words"

            # Step 2: Keyword extraction via Ollama
            echo "=== Auto-prompt Step 2: Keyword extraction ==="
            ollama_ensure_running
            OLLAMA_PROMPT_FILE=$(mktemp)
            cat > "$OLLAMA_PROMPT_FILE" <<'EXTRACT_PROMPT'
Extract vocabulary terms from this speech-to-text transcript that would improve
recognition accuracy. Focus on: proper nouns, domain-specific terminology, technical
jargon. Correct obvious misrecognitions to their likely intended form.
Return ONLY a comma-separated list of terms (max 50), as a single line.
No explanations, no formatting, just the terms.
Transcript:
---
EXTRACT_PROMPT
            echo "$ROUGH_TEXT" >> "$OLLAMA_PROMPT_FILE"
            echo "---" >> "$OLLAMA_PROMPT_FILE"

            AUTO_PROMPT_TEXT=$(curl -s --max-time 300 http://localhost:11434/api/chat \
                -d "$(jq -nc --arg model "$OLLAMA_MODEL" --rawfile prompt "$OLLAMA_PROMPT_FILE" \
                    '{model: $model, messages: [{role: "system", content: "/no_think"}, {role: "user", content: $prompt}], stream: false, think: false, options: {num_predict: 4096}}')" \
                | jq -r '.message.content // empty' 2>/dev/null \
                | sed $'s/\033\[[0-9;]*[a-zA-Z]//g' | tr -s '[:space:]' ' ' | sed 's/^ *//;s/ *$//')
            rm -f "$OLLAMA_PROMPT_FILE"
            ollama_stop_for_gpu

            if [ -z "$AUTO_PROMPT_TEXT" ]; then
                echo "Warning: Ollama empty. Falling back to no prompt."
                AUTO_PROMPT=false
            else
                echo "Prompt v1: ${AUTO_PROMPT_TEXT:0:120}..."

                # Step 3: Refined scan with prompt v1
                echo "=== Auto-prompt Step 3: Refined scan ($SCAN_MODEL + prompt v1) ==="
                echo "$AUTO_PROMPT_TEXT" > "$INPUT_DIR/.whisper_prompt_v1_$$.txt"

                # Run scan with prompt (write prompt to scratch for the pipeline)
                echo "$AUTO_PROMPT_TEXT" > "$SCRATCH/prompt_v1.txt"

                # Use the prompt builder to sanitise the auto-generated prompt
                docker_stage prompt_builder "/audio/$INPUT_BASE.$INPUT_EXT" \
                    --vocab-file "/audio/.whisper-run-$$/prompt_v1.txt" \
                    ${GLOSSARY_MOUNT:+--glossary "/run/glossary.txt"} \
                    ${CONTEXT:+--context "$CONTEXT"} \
                    > "$SCRATCH/prompt_build.json" 2>/dev/null || true

                REFINED_PROMPT=""
                if [ -f "$SCRATCH/prompt_build.json" ]; then
                    REFINED_PROMPT=$(python3 -c "
import json
d = json.load(open('$SCRATCH/prompt_build.json'))
print(d.get('prompt', ''))
" 2>/dev/null || echo "")
                fi
                rm -f "$INPUT_DIR/.whisper_prompt_v1_$$.txt"

                if [ -n "$REFINED_PROMPT" ]; then
                    # Step 4: Keyword refinement via Ollama
                    echo "=== Auto-prompt Step 4: Keyword refinement ==="
                    ollama_ensure_running
                    # Get refined scan text first
                    # (reuse the prompt from prompt_builder for the final pass)
                    ollama_stop_for_gpu
                    AUTO_PROMPT_TEXT="$REFINED_PROMPT"
                    echo "Final prompt: ${AUTO_PROMPT_TEXT:0:120}..."
                else
                    # prompt_builder failed — do NOT fall through to raw LLM output
                    echo "Warning: Prompt sanitisation failed. Disabling auto-prompt."
                    AUTO_PROMPT=false
                    AUTO_PROMPT_TEXT=""
                fi
            fi
        fi
    fi

    # Write the sanitised prompt to a file for the ASR stage
    if $AUTO_PROMPT && [ -n "$AUTO_PROMPT_TEXT" ]; then
        echo "$AUTO_PROMPT_TEXT" > "$SCRATCH/final_prompt.txt"
        PROMPT_FILE_MOUNT="/audio/.whisper-run-$$/final_prompt.txt"
    fi
fi

# Handle manual prompt file
if [ -n "$PROMPT_FILE" ]; then
    PROMPT_FILE_REAL="$(realpath "$PROMPT_FILE")"
    if [ ! -f "$PROMPT_FILE_REAL" ]; then
        echo "Error: Prompt file not found: $PROMPT_FILE"
        exit 1
    fi
    # Use prompt_builder to build from the manual prompt file
    # Mount the prompt file separately since it may be outside INPUT_DIR
    DOCKER_STAGE_EXTRA=("-v" "$PROMPT_FILE_REAL:/run/prompt.txt:ro")
    docker_stage prompt_builder "/audio/$INPUT_BASE.$INPUT_EXT" \
        --vocab-file "/run/prompt.txt" \
        ${GLOSSARY_MOUNT:+--glossary "/run/glossary.txt"} \
        ${CONTEXT:+--context "$CONTEXT"} \
        > "$SCRATCH/prompt_build.json" 2>/dev/null || true
    DOCKER_STAGE_EXTRA=()
    # Extract the .prompt field from the JSON, not the raw JSON blob
    if [ -f "$SCRATCH/prompt_build.json" ]; then
        PROMPT_TEXT=$(python3 -c "
import json
d = json.load(open('$SCRATCH/prompt_build.json'))
print(d.get('prompt', ''))
" 2>/dev/null || echo "")
        if [ -n "$PROMPT_TEXT" ]; then
            echo "$PROMPT_TEXT" > "$SCRATCH/final_prompt.txt"
            PROMPT_FILE_MOUNT="/audio/.whisper-run-$$/final_prompt.txt"
        fi
    fi
fi

# --- Ensure Ollama is stopped for GPU work ---
ollama_stop_for_gpu

echo "=== Transcription: $INPUT_BASE ==="
echo "Model: $MODEL | Quality: ${QUALITY:-custom} (beam=$BEAM_SIZE, best_of=$BEST_OF, batch=$BATCH_SIZE)"
echo "Enhance: $ENHANCE | Denoise: $DENOISE | Ensemble: $ENSEMBLE | Correct: $CORRECT"
echo ""

# --- Stage 1: Audio preprocessing ---
if $ENHANCE || $DENOISE; then
    echo "--- Stage 1: Preprocessing ---"
    docker_stage preprocess "/audio/$INPUT_BASE.$INPUT_EXT" \
        --scratch "/audio/.whisper-run-$$" \
        $( $ENHANCE && echo "--enhance" ) \
        $( $DENOISE && echo "--denoise" )
    AUDIO_INPUT="/audio/.whisper-run-$$/preprocessed.wav"
    echo ""
else
    AUDIO_INPUT="/audio/$INPUT_BASE.$INPUT_EXT"
fi

# Ensure diarization gets a WAV — pyannote/torchaudio cannot read m4a/mp3 etc.
DIARIZE_INPUT="$AUDIO_INPUT"
if [[ "$DIARIZE_INPUT" != *.wav ]]; then
    echo "--- Converting to WAV for diarization ---"
    docker run --rm --gpus all \
        "${DOCKER_ARGS[@]}" \
        --entrypoint ffmpeg \
        "$IMAGE" \
        -i "$AUDIO_INPUT" -ar 16000 -ac 1 -c:a pcm_s16le -y \
        "/audio/.whisper-run-$$/converted.wav"
    DIARIZE_INPUT="/audio/.whisper-run-$$/converted.wav"
fi

# --- Stage 2: ASR ---
echo "--- Stage 2: ASR ($MODEL) ---"
# Map model name to Docker path
case "$MODEL" in
    large-v3) MODEL_PATH="/opt/whisper-models/large-v3" ;;
    *)        MODEL_PATH="$MODEL" ;;  # size names like tiny, base, small, medium handled by WhisperX
esac
ASR_ARGS=(
    "$AUDIO_INPUT"
    --scratch "/audio/.whisper-run-$$"
    --model-path "$MODEL_PATH"
    --batch-size "$BATCH_SIZE"
)
[ -n "$LANGUAGE" ] && [ "$LANGUAGE" != "auto" ] && ASR_ARGS+=(--language "$LANGUAGE")
$ENSEMBLE && ASR_ARGS+=(--ensemble)
[ -n "$HF_TOKEN_MOUNT" ] && ASR_ARGS+=(--hf-token-file "$HF_TOKEN_MOUNT")
[ -n "$PROMPT_FILE_MOUNT" ] && ASR_ARGS+=(--prompt-file "$PROMPT_FILE_MOUNT")

docker_stage asr_engines "${ASR_ARGS[@]}"
echo ""

# --- Stage 3: ROVER (if ensemble) ---
if $ENSEMBLE && [ -f "$SCRATCH/asr_engine_b.json" ]; then
    echo "--- Stage 3: ROVER reconciliation ---"
    ROVER_ARGS=(
        --engine-a "/audio/.whisper-run-$$/asr_engine_a.json"
        --engine-b "/audio/.whisper-run-$$/asr_engine_b.json"
        --output "/audio/.whisper-run-$$/rover.json"
    )
    [ -n "$GLOSSARY_MOUNT" ] && ROVER_ARGS+=(--glossary "$GLOSSARY_MOUNT")
    docker_stage rover "${ROVER_ARGS[@]}"
    echo ""
else
    # No ensemble — copy engine A output as the "rover" output
    cp "$SCRATCH/asr_engine_a.json" "$SCRATCH/rover.json"
fi

# --- Stage 4: Diarization ---
echo "--- Stage 4: Diarization ---"
DIARIZE_ARGS=(
    "${DIARIZE_INPUT}"
    --output "/audio/.whisper-run-$$/diarize.json"
    --model "pyannote/speaker-diarization-$DIARIZE_MODEL"
)
[ -n "$HF_TOKEN_MOUNT" ] && DIARIZE_ARGS+=(--hf-token-file "$HF_TOKEN_MOUNT")
[ -n "$SPEAKERS" ] && DIARIZE_ARGS+=(--speakers "$SPEAKERS")
[ -f "$SCRATCH/preprocessed_L.wav" ] && DIARIZE_ARGS+=(--left "/audio/.whisper-run-$$/preprocessed_L.wav" --right "/audio/.whisper-run-$$/preprocessed_R.wav")
DIARIZE_ARGS+=(--filename-hint "$INPUT_BASE")

docker_stage diarize "${DIARIZE_ARGS[@]}"
echo ""

# --- Stage 5: Post-correction ---
CLEANED_ARG=""
if $CORRECT; then
    echo "--- Stage 5: Post-correction ---"
    BACKEND="ollama"
    $CLOUD_CORRECT && BACKEND="zai"

    POSTCORRECT_ARGS=(
        --rover "/audio/.whisper-run-$$/rover.json"
        --output "/audio/.whisper-run-$$/cleaned.json"
        --language "${LANGUAGE:-nl}"
        --backend "$BACKEND"
    )
    [ -n "$GLOSSARY_MOUNT" ] && POSTCORRECT_ARGS+=(--glossary-file "$GLOSSARY_MOUNT")
    # Only pass --ollama-model if the user explicitly set -o/--ollama-model
    # Don't reuse the auto-selected model from auto-prompt extraction
    if $OLLAMA_MODEL_EXPLICIT && [ -n "$OLLAMA_MODEL" ]; then
        POSTCORRECT_ARGS+=(--ollama-model "$OLLAMA_MODEL")
    fi
    $REFRESH_MODEL && POSTCORRECT_ARGS+=(--refresh-model)

    docker_stage postcorrect "${POSTCORRECT_ARGS[@]}"
    CLEANED_ARG="--cleaned /audio/.whisper-run-$$/cleaned.json"
    echo ""
fi

# --- Stage 6: Render text outputs ---
echo "--- Rendering transcripts ---"
RENDER_ARGS=(
    --rover "/audio/.whisper-run-$$/rover.json"
    --diarize "/audio/.whisper-run-$$/diarize.json"
    --verbatim-out "/audio/$INPUT_BASE.txt"
)
if $CORRECT && [ -f "$SCRATCH/cleaned.json" ]; then
    RENDER_ARGS+=(--cleaned "/audio/.whisper-run-$$/cleaned.json" --cleaned-out "/audio/$INPUT_BASE.cleaned.txt")
fi

docker run --rm "${DOCKER_ARGS[@]}" "$IMAGE" \
    pipeline.render "${RENDER_ARGS[@]}"

# Fix permissions (container writes as root)
chmod 666 "$INPUT_DIR/$INPUT_BASE.txt" 2>/dev/null || true
$CORRECT && chmod 666 "$INPUT_DIR/$INPUT_BASE.cleaned.txt" 2>/dev/null || true

echo ""
echo "Verbatim: $INPUT_DIR/$INPUT_BASE.txt"
$CORRECT && echo "Cleaned:  $INPUT_DIR/$INPUT_BASE.cleaned.txt"

# --- End-of-run summary ---
echo ""
echo "=== Pipeline summary ==="
STAGE_RAN=()
STAGE_SKIPPED=()

if $ENHANCE || $DENOISE; then
    STAGE_RAN+=("preprocess")
    if [ -f "$SCRATCH/preprocess.json" ]; then
        NOTES=$(python3 -c "
import json
d = json.load(open('$SCRATCH/preprocess.json'))
for n in d.get('notes', []): print('  - ' + n)
" 2>/dev/null || true)
        [ -n "$NOTES" ] && echo "$NOTES"
    fi
else
    STAGE_SKIPPED+=("preprocess (enhance/denoise off)")
fi

STAGE_RAN+=("asr ($MODEL)")

if $ENSEMBLE && [ -f "$SCRATCH/asr_engine_b.json" ]; then
    STAGE_RAN+=("ensemble (engine B + ROVER)")
elif $ENSEMBLE; then
    STAGE_SKIPPED+=("ensemble (engine B unavailable)")
else
    STAGE_SKIPPED+=("ensemble (--ensemble off)")
fi

STAGE_RAN+=("diarize")

if $CORRECT && [ -f "$SCRATCH/cleaned.json" ]; then
    N_CORR=$(python3 -c "
import json
d = json.load(open('$SCRATCH/cleaned.json'))
print(sum(1 for s in d.get('segments', []) if 'corrections' in s))
" 2>/dev/null || echo "?")
    STAGE_RAN+=("post-correct ($N_CORR segments fixed)")
elif $CORRECT; then
    STAGE_SKIPPED+=("post-correct (no output produced)")
else
