#!/usr/bin/env bash
# Whisper transcription script with speaker diarization
# Usage: transcribe <audio_file> [--model MODEL] [--language LANG] [--prompt FILE] [--auto-prompt]
#   audio_file   - path to audio/video file (m4a, mp3, wav, mp4, etc.)
#   --model      - tiny, base, small, medium, large-v3 (default: medium)
#   --language   - en, nl, fr, de, auto (default: auto-detect)
#   --prompt     - path to a text file with vocabulary/context hints for Whisper
#   --auto-prompt - auto-generate vocabulary prompt via Ollama (quick scan + keyword extraction)
#   --ollama-model - Ollama model for keyword extraction (default: qwen3.6:35b)
#
# Credentials (read at runtime, never baked into the image):
#   ~/.config/whisper/hf-token  - HuggingFace token for diarization + faster downloads

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
IMAGE="whisper-transcribe"
MODEL="medium"
LANGUAGE=""
INPUT_FILE=""
PROMPT_FILE=""
AUTO_PROMPT=false
OLLAMA_MODEL="qwen3.6:35b"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --model|-m)
            MODEL="$2"; shift 2 ;;
        --language|-l)
            LANGUAGE="$2"; shift 2 ;;
        --prompt|-p)
            PROMPT_FILE="$2"; shift 2 ;;
        --auto-prompt|-a)
            AUTO_PROMPT=true; shift ;;
        --ollama-model|-o)
            OLLAMA_MODEL="$2"; shift 2 ;;
        -h|--help)
            head -8 "$0"; exit 0 ;;
        -*)
            echo "Unknown option: $1"; exit 1 ;;
        *)
            INPUT_FILE="$(realpath "$1")"; shift ;;
    esac
done

if [ -z "$INPUT_FILE" ]; then
    echo "Usage: transcribe <audio_file> [--model MODEL] [--language LANG] [--prompt FILE] [--auto-prompt]"
    exit 1
fi

if $AUTO_PROMPT && [ -n "$PROMPT_FILE" ]; then
    echo "Error: --auto-prompt and --prompt are mutually exclusive"
    exit 1
fi

INPUT_BASE="$(basename "${INPUT_FILE%.*}")"
INPUT_EXT="${INPUT_FILE##*.}"
INPUT_DIR="$(dirname "$INPUT_FILE")"

if [ ! -f "$INPUT_FILE" ]; then
    echo "Error: File not found: $INPUT_FILE"
    exit 1
fi

# Build Docker mount arguments
DOCKER_ARGS=("-v" "$INPUT_DIR:/audio")

# Handle prompt file
PROMPT_PYTHON="initial_prompt = None"
if [ -n "$PROMPT_FILE" ]; then
    PROMPT_FILE="$(realpath "$PROMPT_FILE")"
    if [ ! -f "$PROMPT_FILE" ]; then
        echo "Error: Prompt file not found: $PROMPT_FILE"
        exit 1
    fi
    PROMPT_DIR="$(dirname "$PROMPT_FILE")"
    PROMPT_NAME="$(basename "$PROMPT_FILE")"
    DOCKER_ARGS+=("-v" "$PROMPT_DIR:/prompt")
    PROMPT_PYTHON="
with open('/prompt/$PROMPT_NAME', 'r') as f:
    initial_prompt = f.read().strip()
print(f'Using prompt ({len(initial_prompt)} chars)')
"
fi

# Mount HF token from ~/.config/whisper/hf-token if available
HF_TOKEN_PYTHON="hf_token = None"
if [ -f "$HOME/.config/whisper/hf-token" ]; then
    DOCKER_ARGS+=("-v" "$HOME/.config/whisper/hf-token:/run/secrets/hf-token:ro")
    HF_TOKEN_PYTHON="
with open('/run/secrets/hf-token') as f:
    hf_token = f.read().strip()
print('HF token loaded')
"
fi

# Build image if not present
if ! docker image inspect "$IMAGE" &>/dev/null; then
    echo "Building Whisper image..."
    docker build -t "$IMAGE" "$SCRIPT_DIR"
fi

# --- Auto-prompt: Quick scan + Ollama keyword extraction ---
AUTO_PROMPT_TEXT=""
if $AUTO_PROMPT; then
    # Language flag for quick scan
    QS_LANG_FLAG=""
    if [ -n "$LANGUAGE" ] && [ "$LANGUAGE" != "auto" ]; then
        QS_LANG_FLAG="'$LANGUAGE'"
    else
        QS_LANG_FLAG="None"
    fi

    echo "=== Auto-prompt: Step 1 — Quick scan (base model) ==="
    ROUGH_FILE=$(mktemp)
    docker run --rm --gpus all \
        -v "$INPUT_DIR:/audio" \
        "$IMAGE" \
    "
import whisperx, sys
audio = whisperx.load_audio('/audio/$INPUT_BASE.$INPUT_EXT')
sys.stderr.write('Scanning with base model...\n')
model = whisperx.load_model('base', device='cuda', compute_type='float16', language=$QS_LANG_FLAG)
result = model.transcribe(audio, batch_size=8, language=$QS_LANG_FLAG)
text = ' '.join(s['text'].strip() for s in result['segments'] if s['text'].strip())
sys.stderr.write(f'Detected: {result[\"language\"]} ({len(result[\"segments\"])} segments)\n')
print(text)
" > "$ROUGH_FILE"

    ROUGH_TEXT="$(cat "$ROUGH_FILE")"
    rm -f "$ROUGH_FILE"

    if [ -z "$ROUGH_TEXT" ]; then
        echo "Warning: Quick scan produced no output. Falling back to no prompt."
        AUTO_PROMPT=false
    else
        echo "Quick scan done ($(echo "$ROUGH_TEXT" | wc -w) words extracted)"
        echo ""

        # Step 2: Keyword extraction via Ollama
        echo "=== Auto-prompt: Step 2 — Keyword extraction ($OLLAMA_MODEL) ==="

        # Start Ollama if not running
        OLLAMA_STARTED_FOR_PROMPT=false
        if ! systemctl is-active --quiet ollama 2>/dev/null; then
            echo "Starting Ollama for keyword extraction..."
            sudo systemctl start ollama
            sleep 3
            OLLAMA_STARTED_FOR_PROMPT=true
        fi

        # Check if the Ollama model is available
        if ! ollama list 2>/dev/null | grep -q "$OLLAMA_MODEL"; then
            echo "Warning: Ollama model '$OLLAMA_MODEL' not found. Available models:"
            ollama list 2>/dev/null || echo "  (none — is Ollama running?)"
            echo "Falling back to no prompt."
            AUTO_PROMPT=false
            if $OLLAMA_STARTED_FOR_PROMPT; then
                sudo systemctl stop ollama
            fi
        else
            # Call Ollama to extract keywords — write prompt to temp file to avoid quoting issues
            OLLAMA_PROMPT_FILE=$(mktemp)
            cat > "$OLLAMA_PROMPT_FILE" <<'OLLAMA_HEADER'
You are analyzing a rough speech-to-text transcript. The transcript may contain
errors from the speech recognition system. Your task is to identify key terms
that would help improve recognition accuracy.

Extract and return:
1. The language and dialect (e.g., "Dutch (Flemish)")
2. The domain or topic of the conversation
3. All proper nouns: names of people, places, organizations
4. Domain-specific terminology and jargon
5. Any words that appear to be misspelled or misrecognized

Return ONLY a comma-separated list of these terms, as a single line.
No explanations, no formatting, just the terms.

Transcript:
---
OLLAMA_HEADER
            echo "$ROUGH_TEXT" >> "$OLLAMA_PROMPT_FILE"
            echo "---" >> "$OLLAMA_PROMPT_FILE"

            AUTO_PROMPT_TEXT="$(ollama run "$OLLAMA_MODEL" < "$OLLAMA_PROMPT_FILE" 2>/dev/null)"
            rm -f "$OLLAMA_PROMPT_FILE"

            if $OLLAMA_STARTED_FOR_PROMPT; then
                echo "Stopping Ollama to free GPU memory..."
                sudo systemctl stop ollama
                sleep 2
            fi

            if [ -z "$AUTO_PROMPT_TEXT" ]; then
                echo "Warning: Ollama returned empty result. Falling back to no prompt."
                AUTO_PROMPT=false
            else
                echo "Generated prompt ($(( ${#AUTO_PROMPT_TEXT} )) chars):"
                echo "  $AUTO_PROMPT_TEXT"
                echo ""

                # Write generated prompt to a file for safe Python reading
                PROMPT_TEMP_FILE="$INPUT_DIR/.whisper_auto_prompt_$$.txt"
                echo "$AUTO_PROMPT_TEXT" > "$PROMPT_TEMP_FILE"

                # Mount the prompt file's parent (INPUT_DIR is already /audio)
                # Override PROMPT_PYTHON to read from the mounted file
                PROMPT_PYTHON="
with open('/audio/.whisper_auto_prompt_$$.txt', 'r') as f:
    initial_prompt = f.read().strip()
print(f'Using auto-generated prompt ({len(initial_prompt)} chars)')
"
            fi
        fi
    fi
fi

# --- Main transcription pipeline ---

# Stop Ollama to free VRAM
OLLAMA_WAS_ACTIVE=false
if systemctl is-active --quiet ollama 2>/dev/null; then
    OLLAMA_WAS_ACTIVE=true
    echo "Stopping Ollama to free GPU memory..."
    sudo systemctl stop ollama
    sleep 2
fi

# Ensure Ollama restarts on exit (even on error)
cleanup() {
    if $OLLAMA_WAS_ACTIVE; then
        echo "Restarting Ollama..."
        sudo systemctl start ollama
    fi
    # Clean up auto-prompt temp file
    rm -f "$INPUT_DIR/.whisper_auto_prompt_$$.txt"
}
trap cleanup EXIT

# Language flag
LANG_FLAG=""
if [ -n "$LANGUAGE" ] && [ "$LANGUAGE" != "auto" ]; then
    LANG_FLAG="'$LANGUAGE'"
else
    LANG_FLAG="None"
fi

echo "=== Transcription: $INPUT_BASE ==="
echo "Model: $MODEL"
echo "Output: $INPUT_DIR/$INPUT_BASE.txt"
if $AUTO_PROMPT; then
    echo "Prompt: auto-generated"
elif [ -n "$PROMPT_FILE" ]; then
    echo "Prompt: $(basename "$PROMPT_FILE")"
fi

# Create persistent volume for HuggingFace model cache (survives container restarts)
docker volume create whisper-hf-cache &>/dev/null
DOCKER_ARGS+=("-v" "whisper-hf-cache:/root/.cache/huggingface")

docker run --rm --gpus all \
    "${DOCKER_ARGS[@]}" \
    "$IMAGE" \
"
import sys, time, os
import whisperx
import torch

audio_file = '/audio/$INPUT_BASE.$INPUT_EXT'
language = $LANG_FLAG

$HF_TOKEN_PYTHON

# Set HF token for all downloads if available
if hf_token:
    os.environ['HF_TOKEN'] = hf_token
    os.environ['HUGGING_FACE_HUB_TOKEN'] = hf_token

$PROMPT_PYTHON

print(f'Loading model: $MODEL ...')
model_path = '/opt/whisper-models/large-v3' if '$MODEL' == 'large-v3' else '$MODEL'
asr_opts = {
    'beam_size': 10,
    'best_of': 10,
    'temperatures': [0],
    'condition_on_previous_text': True,
    'compression_ratio_threshold': 2.4,
    'no_speech_threshold': 0.6,
    'log_prob_threshold': -1.0,
}
if initial_prompt:
    asr_opts['initial_prompt'] = initial_prompt
model = whisperx.load_model(model_path, device='cuda', compute_type='float16', language=language, asr_options=asr_opts)
print('Model loaded.')

print(f'Loading audio: {audio_file}')
audio = whisperx.load_audio(audio_file)

print('Transcribing (max quality mode)...')
start = time.time()
result = model.transcribe(
    audio,
    batch_size=8,
    language=language,
)
elapsed = time.time() - start
duration = result['segments'][-1]['end'] if result['segments'] else 0
print(f'Transcription done in {elapsed:.1f}s ({duration/elapsed:.1f}x realtime)')
print(f'Detected language: {result[\"language\"]}')
print(f'Segments: {len(result[\"segments\"])}')
print()

# Align segments for precise timestamps
print('Aligning segments...')
try:
    model_a, metadata = whisperx.load_align_model(language_code=result['language'], device='cuda')
    result = whisperx.align(result['segments'], model_a, metadata, audio, 'cuda')
    del model_a
    torch.cuda.empty_cache()
    print('Alignment done.')
except Exception as e:
    print(f'Alignment skipped: {e}')
    print('(To pre-download: run with --align-only once the model downloads finish)')
print()

# Speaker diarization
if hf_token:
    print('Running speaker diarization...')
    from pyannote.audio import Pipeline as PyannotePipeline
    import torchaudio
    diarize_pipeline = PyannotePipeline.from_pretrained('pyannote/speaker-diarization-3.1', token=hf_token)
    diarize_pipeline = diarize_pipeline.to(torch.device('cuda'))
    # Load audio as wav tensor (pyannote can't decode m4a directly)
    wav_audio, sr = torchaudio.load(audio_file)
    diarize_input = {'waveform': wav_audio, 'sample_rate': sr}
    diarize_segments = diarize_pipeline(diarize_input)
    # Handle both old Annotation and new DiarizeOutput formats
    try:
        diarize_df = [{'start': turn.start, 'end': turn.end, 'speaker': speaker}
                      for turn, _, speaker in diarize_segments.itertracks(yield_label=True)]
    except AttributeError:
        annotation = diarize_segments.speaker_diarization
        diarize_df = [{'start': turn.start, 'end': turn.end, 'speaker': speaker}
                      for turn, _, speaker in annotation.itertracks(yield_label=True)]
    import pandas as pd
    diarize_df = pd.DataFrame(diarize_df)
    result = whisperx.assign_word_speakers(diarize_df, result)
    del diarize_pipeline
    torch.cuda.empty_cache()
    print('Diarization done.')
else:
    print('Skipping speaker diarization (no HF token).')
    print('To enable: save token to ~/.config/whisper/hf-token')
print()

# Print and save
text_lines = []
current_speaker = None
for seg in result['segments']:
    speaker = seg.get('speaker', 'SPEAKER_UNKNOWN')
    line = seg['text'].strip()
    if not line:
        continue
    pct = seg['end'] / duration * 100 if duration > 0 else 0
    print(f'[{pct:5.1f}%] [{speaker}] {line}')
    if speaker != current_speaker:
        text_lines.append('')
        text_lines.append(f'[{speaker}]')
        current_speaker = speaker
    text_lines.append(f'  {line}')

with open('/audio/$INPUT_BASE.txt', 'w') as f:
    f.write('\n'.join(text_lines).strip() + '\n')

print(f'\nSaved to $INPUT_BASE.txt')
"
