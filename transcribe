# --- Summary via Ollama (host-side, after GPU stages complete) ---
if $SUMMARY; then
    OUTPUT_FILE="$INPUT_DIR/$INPUT_BASE.txt"
    if [ ! -f "$OUTPUT_FILE" ]; then
        echo "Warning: Transcript not found, skipping summary."
    else
        echo ""
        echo "=== Summary ==="
        ollama_ensure_running
        if [ -z "$OLLAMA_MODEL" ]; then
            OLLAMA_MODEL="$(select_ollama_model)"
        fi
        if [ -z "$OLLAMA_MODEL" ]; then
            echo "Warning: No Ollama model. Skipping summary."
        else
            echo "Using Ollama: $OLLAMA_MODEL"
            SUMMARY_PROMPT_FILE=$(mktemp)
            cat > "$SUMMARY_PROMPT_FILE" <<'SUMMARY_PROMPT'
Analyze this meeting transcript and provide:
1. A concise summary (3-5 sentences)
2. Key decisions or conclusions
3. Action items, follow-ups or open questions

Use the same language as the transcript. Be specific with names, places, numbers.

Format:

## Samenvatting
<summary>

## Beslissingen
- <decisions>

## Actiepunten
- [ ] <action items>

Transcript:
---
SUMMARY_PROMPT
            cat "$OUTPUT_FILE" >> "$SUMMARY_PROMPT_FILE"
            echo "---" >> "$SUMMARY_PROMPT_FILE"

            SUMMARY_TEXT=$(curl -s --max-time 300 http://localhost:11434/api/chat \
                -d "$(jq -nc --arg model "$OLLAMA_MODEL" --rawfile prompt "$SUMMARY_PROMPT_FILE" \
                    '{model: $model, messages: [{role: "system", content: "/no_think"}, {role: "user", content: $prompt}], stream: false, think: false, options: {num_predict: 4096}}')" \
                | jq -r '.message.content // empty' 2>/dev/null \
                | sed $'s/\033\[[0-9;]*[a-zA-Z]//g' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
            rm -f "$SUMMARY_PROMPT_FILE"
            ollama_stop_for_gpu

            if [ -n "$SUMMARY_TEXT" ]; then
                { echo ""; echo "---"; echo ""; echo "$SUMMARY_TEXT"; } >> "$OUTPUT_FILE"
                echo "Summary appended."
            else
                echo "Warning: Empty summary."
            fi
        fi
    fi
fi

echo ""
echo "Done."
