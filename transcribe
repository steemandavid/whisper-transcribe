#!/usr/bin/env bash
# Whisper transcription script with speaker diarization
# Usage: transcribe <audio_file> [--quality QUALITY] [--model MODEL] [--language LANG] [--prompt FILE] [--auto-prompt] [--summary]
#   audio_file   - path to audio/video file (m4a, mp3, wav, mp4, etc.)
#   --quality    - fast, medium, good, perfect — preset for scan model, final model and quality params
#   --model      - tiny, base, small, medium, large-v3 (overrides quality preset's final model)
#   --language   - en, nl, fr, de, auto (default: auto-detect)
#   --prompt     - path to a text file with vocabulary/context hints for Whisper
#   --auto-prompt - auto-generate vocabulary prompt via Ollama (quick scan + keyword extraction)
#   --summary    - append LLM-generated summary, decisions and action items to the transcript
#   --ollama-model - Ollama model for keyword extraction (default: auto-select best available)
#
# Credentials (read at runtime, never baked into the image):
#   ~/.config/whisper/hf-token  - HuggingFace token for diarization + faster downloads

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
IMAGE="whisper-transcribe"
MODEL="medium"
LANGUAGE=""
INPUT_FILE=""
PROMPT_FILE=""
AUTO_PROMPT=false
SUMMARY=false
OLLAMA_MODEL=""
QUALITY=""
MODEL_EXPLICIT=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --model|-m)
            MODEL="$2"; MODEL_EXPLICIT=true; shift 2 ;;
        --language|-l)
            LANGUAGE="$2"; shift 2 ;;
        --prompt|-p)
            PROMPT_FILE="$2"; shift 2 ;;
        --auto-prompt|-a)
            AUTO_PROMPT=true; shift ;;
        --summary|-s)
            SUMMARY=true; shift ;;
        --ollama-model|-o)
            OLLAMA_MODEL="$2"; shift 2 ;;
        --quality|-Q)
            QUALITY="$2"; shift 2 ;;
        -h|--help)
            head -8 "$0"; exit 0 ;;
        -*)
            echo "Unknown option: $1"; exit 1 ;;
        *)
            INPUT_FILE="$(realpath "$1")"; shift ;;
    esac
done

if [ -z "$INPUT_FILE" ]; then
    echo "Usage: transcribe <audio_file> [--quality QUALITY] [--model MODEL] [--language LANG] [--prompt FILE] [--auto-prompt] [--summary]"
    exit 1
fi

if $AUTO_PROMPT && [ -n "$PROMPT_FILE" ]; then
    echo "Error: --auto-prompt and --prompt are mutually exclusive"
    exit 1
fi

# --- Quality presets ---
# Each preset configures: scan model (auto-prompt quick scans), final model, and quality parameters.
# --model overrides the final model from the preset.
if [ -n "$QUALITY" ]; then
    case "$QUALITY" in
        fast)
            SCAN_MODEL="base"
            BEAM_SIZE=2
            BEST_OF=2
            BATCH_SIZE=16
            QUALITY_MODEL="small"
            ;;
        medium)
            SCAN_MODEL="base"
            BEAM_SIZE=5
            BEST_OF=5
            BATCH_SIZE=12
            QUALITY_MODEL="medium"
            ;;
        good)
            SCAN_MODEL="medium"
            BEAM_SIZE=10
            BEST_OF=10
            BATCH_SIZE=8
            QUALITY_MODEL="large-v3"
            ;;
        perfect)
            SCAN_MODEL="large-v3"
            BEAM_SIZE=10
            BEST_OF=10
            BATCH_SIZE=8
            QUALITY_MODEL="large-v3"
            ;;
        *)
            echo "Error: Unknown quality level '$QUALITY' (choose: fast, medium, good, perfect)"
            exit 1
            ;;
    esac
    # --model overrides the quality preset's final model
    if $MODEL_EXPLICIT; then
        QUALITY_MODEL="$MODEL"
    fi
else
    # No quality preset — use --model (default: medium) with max quality params
    SCAN_MODEL="medium"
    QUALITY_MODEL="$MODEL"
    BEAM_SIZE=10
    BEST_OF=10
    BATCH_SIZE=8
fi

# Pre-loaded model path for large-v3 scans
if [ "$SCAN_MODEL" = "large-v3" ]; then
    SCAN_MODEL_PATH="/opt/whisper-models/large-v3"
else
    SCAN_MODEL_PATH="$SCAN_MODEL"
fi

# Apply the resolved model
MODEL="$QUALITY_MODEL"

INPUT_BASE="$(basename "${INPUT_FILE%.*}")"
INPUT_EXT="${INPUT_FILE##*.}"
INPUT_DIR="$(dirname "$INPUT_FILE")"

if [ ! -f "$INPUT_FILE" ]; then
    echo "Error: File not found: $INPUT_FILE"
    exit 1
fi

# Build Docker mount arguments
DOCKER_ARGS=("-v" "$INPUT_DIR:/audio")

# Handle prompt file
PROMPT_PYTHON="initial_prompt = None"
if [ -n "$PROMPT_FILE" ]; then
    PROMPT_FILE="$(realpath "$PROMPT_FILE")"
    if [ ! -f "$PROMPT_FILE" ]; then
        echo "Error: Prompt file not found: $PROMPT_FILE"
        exit 1
    fi
    PROMPT_DIR="$(dirname "$PROMPT_FILE")"
    PROMPT_NAME="$(basename "$PROMPT_FILE")"
    DOCKER_ARGS+=("-v" "$PROMPT_DIR:/prompt")
    PROMPT_PYTHON="
with open('/prompt/$PROMPT_NAME', 'r') as f:
    initial_prompt = f.read().strip()
print(f'Using prompt ({len(initial_prompt)} chars)')
"
fi

# Mount HF token from ~/.config/whisper/hf-token if available
HF_TOKEN_PYTHON="hf_token = None"
if [ -f "$HOME/.config/whisper/hf-token" ]; then
    DOCKER_ARGS+=("-v" "$HOME/.config/whisper/hf-token:/run/secrets/hf-token:ro")
    HF_TOKEN_PYTHON="
with open('/run/secrets/hf-token') as f:
    hf_token = f.read().strip()
print('HF token loaded')
"
fi

# Build image if not present
if ! docker image inspect "$IMAGE" &>/dev/null; then
    echo "Building Whisper image..."
    docker build -t "$IMAGE" "$SCRIPT_DIR"
fi

# Auto-select the best available Ollama model for keyword extraction.
# Prefers newer and larger general-purpose models; excludes embedding models;
# penalizes coder-specific models; applies generation bonus (qwen3 > qwen2.5).
select_ollama_model() {
    ollama list 2>/dev/null | awk '
    NR == 1 { next }
    tolower($1) ~ /embed/ { next }
    {
        if ($4 == "GB") size = $3 * 1024;
        else if ($4 == "MB") size = $3;
        else size = 0;
        # Penalize coder-specific models
        if (tolower($1) ~ /coder/) size *= 0.7;
        # Penalize thinking models (qwen3) — cannot reliably disable thinking mode
        if (tolower($1) ~ /^qwen3/) size *= 0.5;
        # Bonus for instruct variants (better at following extraction prompts)
        if (tolower($1) ~ /instruct/) size *= 1.3;
        # Generation bonus: prefer newer model families
        ver = 1.0;
        if (match(tolower($1), /[0-9]+(\.[0-9]+)?/)) {
            ver = substr(tolower($1), RSTART, RLENGTH) + 0;
        }
        gen_bonus = 1.0 + ver * 0.2;
        effective = size * gen_bonus;
        if (effective > best) { best = effective; name = $1 }
    }
    END { if (name != "") print name }'
}

# Track original Ollama state for cleanup
OLLAMA_WAS_ACTIVE=false
if systemctl is-active --quiet ollama 2>/dev/null; then
    OLLAMA_WAS_ACTIVE=true
fi

# Cleanup: restart Ollama if it was running before the script, remove temp files
cleanup() {
    if $OLLAMA_WAS_ACTIVE; then
        echo "Restarting Ollama..."
        sudo systemctl start ollama
    fi
    rm -f "$INPUT_DIR/.whisper_auto_prompt_$$.txt"
    rm -f "$INPUT_DIR/.whisper_prompt_v1_$$.txt"
}
trap cleanup EXIT

# Helper functions for Ollama lifecycle
ollama_ensure_running() {
    if ! systemctl is-active --quiet ollama 2>/dev/null; then
        echo "Starting Ollama..."
        sudo systemctl start ollama
        sleep 3
    fi
}
ollama_stop_for_gpu() {
    if systemctl is-active --quiet ollama 2>/dev/null; then
        echo "Stopping Ollama to free GPU memory..."
        sudo systemctl stop ollama
        sleep 2
    fi
}

# Run an Ollama prompt via the /api/chat endpoint.
# Uses /no_think system message to suppress qwen3 thinking mode,
# and extracts only the .message.content field for the clean response.
ollama_extract() {
    local prompt_file="$1"
    local preserve_newlines="${2:-false}"
    local json_file
    json_file=$(mktemp)
    jq -nc --arg model "$OLLAMA_MODEL" --rawfile prompt "$prompt_file" \
        '{model: $model, messages: [{role: "system", content: "/no_think"}, {role: "user", content: $prompt}], stream: false, think: false, options: {num_predict: 4096}}' > "$json_file" 2>/dev/null
    local raw_response
    raw_response=$(curl -s --max-time 300 http://localhost:11434/api/chat -d @"$json_file" 2>/dev/null)
    rm -f "$json_file"
    if [ -z "$raw_response" ]; then
        echo "Warning: Ollama API returned empty response" >&2
        echo ""
        return
    fi
    local result
    if $preserve_newlines; then
        result=$(echo "$raw_response" | jq -r '.message.content // empty' 2>/dev/null \
            | sed $'s/\033\[[0-9;]*[a-zA-Z]//g' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    else
        result=$(echo "$raw_response" | jq -r '.message.content // empty' 2>/dev/null \
            | sed $'s/\033\[[0-9;]*[a-zA-Z]//g' | tr -s '[:space:]' ' ' | sed 's/^ *//;s/ *$//')
    fi
    if [ -z "$result" ]; then
        echo "Warning: Ollama .message.content field is empty (raw: $(echo "$raw_response" | head -c 200))" >&2
    fi
    echo "$result"
}

# --- Auto-prompt: iterative scan + Ollama keyword extraction ---
AUTO_PROMPT_TEXT=""
if $AUTO_PROMPT; then
    # Language flag for scans
    QS_LANG_FLAG=""
    if [ -n "$LANGUAGE" ] && [ "$LANGUAGE" != "auto" ]; then
        QS_LANG_FLAG="'$LANGUAGE'"
    else
        QS_LANG_FLAG="None"
    fi

    # Resolve Ollama model once, before any scans
    ollama_ensure_running
    if [ -n "$OLLAMA_MODEL" ] && ollama list 2>/dev/null | grep -q "$OLLAMA_MODEL"; then
        echo "Using Ollama model: $OLLAMA_MODEL"
    else
        if [ -n "$OLLAMA_MODEL" ]; then
            echo "Warning: Ollama model '$OLLAMA_MODEL' not found."
        fi
        echo "Auto-selecting best available model..."
        OLLAMA_MODEL="$(select_ollama_model)"
        if [ -z "$OLLAMA_MODEL" ]; then
            echo "Warning: No suitable Ollama model found. Available models:"
            ollama list 2>/dev/null || echo "  (none — is Ollama running?)"
            echo "Falling back to no prompt."
            AUTO_PROMPT=false
        else
            echo "Auto-selected: $OLLAMA_MODEL"
        fi
    fi
    ollama_stop_for_gpu

    if $AUTO_PROMPT; then
        # === Step 1: Quick scan (no prompt) → rough text ===
        echo "=== Auto-prompt: Step 1 — Quick scan ($SCAN_MODEL model) ==="
        ROUGH_FILE=$(mktemp)
        docker run --rm --gpus all \
            -v "$INPUT_DIR:/audio" \
            -v "whisper-hf-cache:/root/.cache/huggingface" \
            "$IMAGE" \
        "
import whisperx, sys, logging
logging.getLogger('whisperx').setLevel(logging.WARNING)
logging.getLogger('pyannote').setLevel(logging.WARNING)
audio = whisperx.load_audio('/audio/$INPUT_BASE.$INPUT_EXT')
sys.stderr.write('Scanning with $SCAN_MODEL model...\n')
model = whisperx.load_model('$SCAN_MODEL_PATH', device='cuda', compute_type='float16', language=$QS_LANG_FLAG)
result = model.transcribe(audio, batch_size=8, language=$QS_LANG_FLAG)
text = ' '.join(s['text'].strip() for s in result['segments'] if s['text'].strip())
sys.stderr.write(f'Detected: {result[\"language\"]} ({len(result[\"segments\"])} segments)\n')
print(text)
" > "$ROUGH_FILE"

        ROUGH_TEXT="$(grep -v '^[0-9]\{4\}-[0-9]\{2\}-[0-9]\{2\}' "$ROUGH_FILE" | grep -v '^$')"
        rm -f "$ROUGH_FILE"

        if [ -z "$ROUGH_TEXT" ]; then
            echo "Warning: Quick scan produced no output. Falling back to no prompt."
            AUTO_PROMPT=false
        else
            echo "Quick scan done ($(echo "$ROUGH_TEXT" | wc -w) words extracted)"
            echo ""

            # === Step 2: LLM keyword extraction → prompt v1 ===
            echo "=== Auto-prompt: Step 2 — Keyword extraction ==="
            ollama_ensure_running

            OLLAMA_PROMPT_FILE=$(mktemp)
            cat > "$OLLAMA_PROMPT_FILE" <<'OLLAMA_HEADER'
Extract vocabulary terms from this speech-to-text transcript that would improve
recognition accuracy. Focus on: proper nouns (people, places, organizations),
domain-specific terminology, and technical jargon. Correct any obvious
misrecognitions to their likely intended form.

Return ONLY a comma-separated list of terms (max 50), as a single line.
No explanations, no formatting, just the terms.

Transcript:
---
OLLAMA_HEADER
            echo "$ROUGH_TEXT" >> "$OLLAMA_PROMPT_FILE"
            echo "---" >> "$OLLAMA_PROMPT_FILE"

            AUTO_PROMPT_TEXT="$(ollama_extract "$OLLAMA_PROMPT_FILE")"
            rm -f "$OLLAMA_PROMPT_FILE"
            ollama_stop_for_gpu

            if [ -z "$AUTO_PROMPT_TEXT" ]; then
                echo "Warning: Ollama returned empty result. Falling back to no prompt."
                AUTO_PROMPT=false
            else
                echo "Generated prompt v1 ($(( ${#AUTO_PROMPT_TEXT} )) chars):"
                echo "  $AUTO_PROMPT_TEXT"
                echo ""

                # === Step 3: Scan with prompt v1 → cleaner text ===
                echo "=== Auto-prompt: Step 3 — Refined scan ($SCAN_MODEL model + prompt v1) ==="

                # Write prompt v1 to temp file for the scan container
                PROMPT_V1_FILE="$INPUT_DIR/.whisper_prompt_v1_$$.txt"
                echo "$AUTO_PROMPT_TEXT" > "$PROMPT_V1_FILE"

                REFINED_FILE=$(mktemp)
                docker run --rm --gpus all \
                    -v "$INPUT_DIR:/audio" \
                    -v "whisper-hf-cache:/root/.cache/huggingface" \
                    "$IMAGE" \
                "
import whisperx, sys, logging
logging.getLogger('whisperx').setLevel(logging.WARNING)
logging.getLogger('pyannote').setLevel(logging.WARNING)
audio = whisperx.load_audio('/audio/$INPUT_BASE.$INPUT_EXT')
sys.stderr.write('Scanning with $SCAN_MODEL model + prompt...\n')
with open('/audio/.whisper_prompt_v1_$$.txt', 'r') as f:
    prompt_text = f.read().strip()
sys.stderr.write(f'Using prompt ({len(prompt_text)} chars)\n')
model = whisperx.load_model('$SCAN_MODEL_PATH', device='cuda', compute_type='float16', language=$QS_LANG_FLAG,
    asr_options={'initial_prompt': prompt_text})
result = model.transcribe(audio, batch_size=8, language=$QS_LANG_FLAG)
text = ' '.join(s['text'].strip() for s in result['segments'] if s['text'].strip())
sys.stderr.write(f'Detected: {result[\"language\"]} ({len(result[\"segments\"])} segments)\n')
print(text)
" > "$REFINED_FILE"
                rm -f "$PROMPT_V1_FILE"

                REFINED_TEXT="$(grep -v '^[0-9]\{4\}-[0-9]\{2\}-[0-9]\{2\}' "$REFINED_FILE" | grep -v '^$')"
                rm -f "$REFINED_FILE"

                if [ -z "$REFINED_TEXT" ]; then
                    echo "Warning: Refined scan produced no output. Using prompt v1."
                else
                    echo "Refined scan done ($(echo "$REFINED_TEXT" | wc -w) words extracted)"
                    echo ""

                    # === Step 4: LLM keyword refinement → prompt v2 ===
                    echo "=== Auto-prompt: Step 4 — Keyword refinement ==="
                    ollama_ensure_running

                    OLLAMA_REFINE_FILE=$(mktemp)
                    cat > "$OLLAMA_REFINE_FILE" <<'OLLAMA_REFINE'
Refine the vocabulary for speech-to-text transcription. Based on this cleaner
transcript: keep correct proper nouns and domain terms, remove transcription
errors, add missed important terms. No common words or filler.

Return ONLY a comma-separated list of terms (max 50), as a single line.
No explanations, no formatting, just the terms.

Transcript:
---
OLLAMA_REFINE
                    echo "$REFINED_TEXT" >> "$OLLAMA_REFINE_FILE"
                    echo "---" >> "$OLLAMA_REFINE_FILE"

                    REFINED_PROMPT="$(ollama_extract "$OLLAMA_REFINE_FILE")"
                    rm -f "$OLLAMA_REFINE_FILE"
                    ollama_stop_for_gpu

                    if [ -n "$REFINED_PROMPT" ]; then
                        echo "Refined prompt v2 ($(( ${#REFINED_PROMPT} )) chars):"
                        echo "  $REFINED_PROMPT"
                        echo ""
                        AUTO_PROMPT_TEXT="$REFINED_PROMPT"
                    else
                        echo "Warning: LLM refinement returned empty. Using prompt v1."
                    fi
                fi
            fi
        fi
    fi

    # Write final prompt to file for the main transcription pass
    if $AUTO_PROMPT && [ -n "$AUTO_PROMPT_TEXT" ]; then
        PROMPT_TEMP_FILE="$INPUT_DIR/.whisper_auto_prompt_$$.txt"
        echo "$AUTO_PROMPT_TEXT" > "$PROMPT_TEMP_FILE"
        PROMPT_PYTHON="
with open('/audio/.whisper_auto_prompt_$$.txt', 'r') as f:
    initial_prompt = f.read().strip()
print(f'Using auto-generated prompt ({len(initial_prompt)} chars)')
"
    fi
fi

# --- Main transcription pipeline ---

# Ensure Ollama is stopped for GPU transcription (should already be, but verify)
ollama_stop_for_gpu

# Language flag
LANG_FLAG=""
if [ -n "$LANGUAGE" ] && [ "$LANGUAGE" != "auto" ]; then
    LANG_FLAG="'$LANGUAGE'"
else
    LANG_FLAG="None"
fi

echo "=== Transcription: $INPUT_BASE ==="
echo "Model: $MODEL"
echo "Quality: ${QUALITY:-custom} (beam=$BEAM_SIZE, best_of=$BEST_OF, batch=$BATCH_SIZE)"
echo "Output: $INPUT_DIR/$INPUT_BASE.txt"
if $AUTO_PROMPT; then
    echo "Prompt: auto-generated"
elif [ -n "$PROMPT_FILE" ]; then
    echo "Prompt: $(basename "$PROMPT_FILE")"
fi

# Create persistent volume for HuggingFace model cache (survives container restarts)
docker volume create whisper-hf-cache &>/dev/null
DOCKER_ARGS+=("-v" "whisper-hf-cache:/root/.cache/huggingface")

docker run --rm --gpus all \
    "${DOCKER_ARGS[@]}" \
    "$IMAGE" \
"
import sys, time, os
import whisperx
import torch

audio_file = '/audio/$INPUT_BASE.$INPUT_EXT'
language = $LANG_FLAG

$HF_TOKEN_PYTHON

# Set HF token for all downloads if available
if hf_token:
    os.environ['HF_TOKEN'] = hf_token
    os.environ['HUGGING_FACE_HUB_TOKEN'] = hf_token

$PROMPT_PYTHON

print(f'Loading model: $MODEL ...')
model_path = '/opt/whisper-models/large-v3' if '$MODEL' == 'large-v3' else '$MODEL'
asr_opts = {
    'beam_size': $BEAM_SIZE,
    'best_of': $BEST_OF,
    'temperatures': [0],
    'condition_on_previous_text': True,
    'compression_ratio_threshold': 2.4,
    'no_speech_threshold': 0.6,
    'log_prob_threshold': -1.0,
}
if initial_prompt:
    asr_opts['initial_prompt'] = initial_prompt
model = whisperx.load_model(model_path, device='cuda', compute_type='float16', language=language, asr_options=asr_opts)
print('Model loaded.')

print(f'Loading audio: {audio_file}')
audio = whisperx.load_audio(audio_file)

print('Transcribing (beam_size=$BEAM_SIZE, best_of=$BEST_OF, batch=$BATCH_SIZE)...')
start = time.time()
result = model.transcribe(
    audio,
    batch_size=$BATCH_SIZE,
    language=language,
)
elapsed = time.time() - start
duration = result['segments'][-1]['end'] if result['segments'] else 0
print(f'Transcription done in {elapsed:.1f}s ({duration/elapsed:.1f}x realtime)')
print(f'Detected language: {result[\"language\"]}')
print(f'Segments: {len(result[\"segments\"])}')
print()

# Align segments for precise timestamps
print('Aligning segments...')
try:
    model_a, metadata = whisperx.load_align_model(language_code=result['language'], device='cuda')
    result = whisperx.align(result['segments'], model_a, metadata, audio, 'cuda')
    del model_a
    torch.cuda.empty_cache()
    print('Alignment done.')
except Exception as e:
    print(f'Alignment skipped: {e}')
    print('(To pre-download: run with --align-only once the model downloads finish)')
print()

# Speaker diarization
if hf_token:
    print('Running speaker diarization...')
    from pyannote.audio import Pipeline as PyannotePipeline
    import torchaudio
    diarize_pipeline = PyannotePipeline.from_pretrained('pyannote/speaker-diarization-3.1', token=hf_token)
    diarize_pipeline = diarize_pipeline.to(torch.device('cuda'))
    # Load audio as wav tensor (pyannote can't decode m4a directly)
    wav_audio, sr = torchaudio.load(audio_file)
    diarize_input = {'waveform': wav_audio, 'sample_rate': sr}
    diarize_segments = diarize_pipeline(diarize_input)
    # Handle both old Annotation and new DiarizeOutput formats
    try:
        diarize_df = [{'start': turn.start, 'end': turn.end, 'speaker': speaker}
                      for turn, _, speaker in diarize_segments.itertracks(yield_label=True)]
    except AttributeError:
        annotation = diarize_segments.speaker_diarization
        diarize_df = [{'start': turn.start, 'end': turn.end, 'speaker': speaker}
                      for turn, _, speaker in annotation.itertracks(yield_label=True)]
    import pandas as pd
    diarize_df = pd.DataFrame(diarize_df)
    result = whisperx.assign_word_speakers(diarize_df, result)
    del diarize_pipeline
    torch.cuda.empty_cache()
    print('Diarization done.')
else:
    print('Skipping speaker diarization (no HF token).')
    print('To enable: save token to ~/.config/whisper/hf-token')
print()

# Print and save
text_lines = []
current_speaker = None
for seg in result['segments']:
    speaker = seg.get('speaker', 'SPEAKER_UNKNOWN')
    line = seg['text'].strip()
    if not line:
        continue
    pct = seg['end'] / duration * 100 if duration > 0 else 0
    print(f'[{pct:5.1f}%] [{speaker}] {line}')
    if speaker != current_speaker:
        text_lines.append('')
        text_lines.append(f'[{speaker}]')
        current_speaker = speaker
    text_lines.append(f'  {line}')

with open('/audio/$INPUT_BASE.txt', 'w') as f:
    f.write('\n'.join(text_lines).strip() + '\n')
os.chmod('/audio/$INPUT_BASE.txt', 0o666)

print(f'\nSaved to $INPUT_BASE.txt')
"

# --- Summary via Ollama ---
if $SUMMARY; then
    OUTPUT_FILE="$INPUT_DIR/$INPUT_BASE.txt"
    if [ ! -f "$OUTPUT_FILE" ]; then
        echo "Warning: Transcript file not found, skipping summary."
    else
        echo ""
        echo "=== Summary ==="
        echo "Generating summary, decisions and action items..."

        # Resolve Ollama model (reuse auto-prompt selection logic)
        ollama_ensure_running
        if [ -n "$OLLAMA_MODEL" ] && ollama list 2>/dev/null | grep -q "$OLLAMA_MODEL"; then
            echo "Using Ollama model: $OLLAMA_MODEL"
        else
            if [ -n "$OLLAMA_MODEL" ]; then
                echo "Warning: Ollama model '$OLLAMA_MODEL' not found."
            fi
            echo "Auto-selecting best available model..."
            OLLAMA_MODEL="$(select_ollama_model)"
            if [ -z "$OLLAMA_MODEL" ]; then
                echo "Warning: No suitable Ollama model found. Skipping summary."
                ollama_stop_for_gpu
                OLLAMA_MODEL=""
            else
                echo "Auto-selected: $OLLAMA_MODEL"
            fi
        fi
    fi

    if $SUMMARY && [ -n "$OLLAMA_MODEL" ]; then
        SUMMARY_PROMPT_FILE=$(mktemp)
        cat > "$SUMMARY_PROMPT_FILE" <<'SUMMARY_PROMPT'
Analyze this meeting transcript and provide:
1. A concise summary of the conversation (3-5 sentences)
2. A list of key decisions or conclusions reached
3. A list of action items, follow-ups or open questions

Use the same language as the transcript. Be specific — include names, places, numbers mentioned.

Format your response exactly as:

## Samenvatting
<summary here>

## Beslissingen
- <decision 1>
- <decision 2>

## Actiepunten
- [ ] <action item 1>
- [ ] <action item 2>

If there are no decisions or action items, write "Geen" (or equivalent in the transcript's language) under that section.

Transcript:
---
SUMMARY_PROMPT
        cat "$OUTPUT_FILE" >> "$SUMMARY_PROMPT_FILE"
        echo "---" >> "$SUMMARY_PROMPT_FILE"

        SUMMARY_TEXT="$(ollama_extract "$SUMMARY_PROMPT_FILE" true)"
        rm -f "$SUMMARY_PROMPT_FILE"
        ollama_stop_for_gpu

        if [ -z "$SUMMARY_TEXT" ]; then
            echo "Warning: LLM returned empty summary."
        else
            # Append summary to the transcript file
            {
                echo ""
                echo "---"
                echo ""
                echo "$SUMMARY_TEXT"
            } >> "$OUTPUT_FILE"
            echo "Summary appended to $INPUT_BASE.txt"
        fi
    fi
fi
